#!/usr/bin/env python3
"""
iram_flash.py — load a firmware binary into IRAM via shell commands.

Usage:
    python3 iram_flash.py [--port PORT] [--baud BAUD] [--addr ADDR] [--no-reboot] BINARY

Arguments:
    BINARY              Path to .bin file (e.g. build/freertos_shell--iram.bin)

Options:
    --port PORT         Serial port (default: /dev/ttyUSB0)
    --baud BAUD         Baud rate   (default: 115200)
    --addr ADDR         Load address in hex (default: 0x00900000)
    --no-reboot         Skip reboot step, assume shell is already running
    --no-jump           Load binary but do not jump to entry point
    --timeout SECONDS   Serial read timeout in seconds (default: 10)
"""

import sys
import time
import argparse
import serial
import zlib


# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

def log(msg: str):
    print(f"  {msg}", flush=True)

def log_ok(msg: str):
    print(f"  \033[32m✓\033[0m {msg}", flush=True)

def log_debug(msg: str):
    print(f"  \033[34m#\033[0m {msg}", flush=True)

def log_warn(msg: str):
    print(f"  \033[33m!\033[0m {msg}", flush=True)

def log_err(msg: str):
    print(f"  \033[31m✗\033[0m {msg}", flush=True)

def die(msg: str):
    log_err(msg)
    sys.exit(1)


# ---------------------------------------------------------------------------
# Serial helpers
# ---------------------------------------------------------------------------

def readline(ser: serial.Serial, timeout: float = 2.0) -> tuple[str, bool]:
    ser.timeout = 0.1
    buf = b''
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        c = ser.read(1)
        if not c:
            continue
        if c in (b'\r', b'\n'):
            line = buf.decode(errors="ignore").strip()
            if line == '':
                continue
            return line, False
        buf += c
    return buf.decode(errors="ignore").strip(), True  # True = timeout


def wait_for_prompt(ser: serial.Serial, timeout: float = 2.0) -> bool:
    """
    Read lines until we see a bare '>' prompt (no spaces — shell convention).
    Returns True on success, False on timeout.
    """
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        line, is_timeout = readline(ser, 1)
        if line == ">":
            return True
        if is_timeout:
            ser.write(b"\x03")
    return False


# ---------------------------------------------------------------------------
# Steps
# ---------------------------------------------------------------------------

def step_reboot(ser: serial.Serial, timeout: float):
    log("Sending Ctrl+C to clear shell input...")
    ser.write(b"\x03\x03")
    time.sleep(0.2)
    ser.reset_input_buffer()

    log("Sending reboot command...")
    ser.write(b"reboot\n")

    log("Waiting for shell prompt after reboot...")
    if not wait_for_prompt(ser, timeout):
        die("Timed out waiting for shell prompt after reboot.")
    log_ok("Shell is ready.")


def step_ensure_prompt(ser: serial.Serial):
    """Used with --no-reboot: send Ctrl+C, expect prompt immediately."""
    ser.write(b"\x03")
    ser.reset_input_buffer()

    if not wait_for_prompt(ser, timeout=2.0):
        die("No shell prompt detected. Is the device running?")
    log_ok("Shell is ready.")
    time.sleep(0.2)
    ser.reset_input_buffer()


def step_load(ser: serial.Serial, addr: int, data: bytes, timeout: float) -> int:
    """
    Send iram_load command, stream binary, verify DONE + CRC.
    Returns CRC32 reported by firmware.
    """
    size = len(data)
    cmd = f"iram_load 0x{addr:08x} {size}"
    log(f"Sending: {cmd}")
    ser.write((cmd + "\n").encode())

    # Read echo
    echo, is_timeout = readline(ser, timeout)
    if echo != cmd.strip():
        log_warn(f"echo mismatch: {echo!r}")

    # Wait for READY
    ready, is_timeout = readline(ser, timeout)
    if ready != "READY":
        die(f"Expected READY, got: {ready!r}")
    log_ok("Device is ready to receive data.")

    # Stream binary in chunks for progress reporting
    chunk_size = 256
    sent = 0
    t_start = time.monotonic()
    while sent < size:
        chunk = data[sent:sent + chunk_size]
        ser.write(chunk)
        sent += len(chunk)
        pct = sent * 100 // size
        elapsed = time.monotonic() - t_start
        speed = sent / elapsed / 1024 if elapsed > 0 else 0
        print(f"\r  Uploading... {sent}/{size} bytes ({pct}%) {speed:.1f} KB/s", end="", flush=True)

    print()  # newline after progress

    # Wait for DONE <crc32>
    done_line, is_timeout = readline(ser, timeout)
    if not done_line.startswith("DONE"):
        die(f"Expected DONE <crc32>, got: {done_line!r}")

    parts = done_line.split()
    if len(parts) != 2:
        die(f"Malformed DONE line: {done_line!r}")

    fw_crc = int(parts[1], 16)
    return fw_crc


def step_verify(data: bytes, fw_crc: int) -> bool:
    local_crc = zlib.crc32(data)
    if local_crc != fw_crc:
        log_warn(f"CRC mismatch! local=0x{local_crc:08x} firmware=0x{fw_crc:08x}")
        return False
    log_ok(f"CRC32 OK: 0x{local_crc:08x}")
    return True


def step_jump(ser: serial.Serial, addr: int, timeout: float):
    cmd = f"iram_jump 0x{addr:08x}"
    log(f"Sending: {cmd}")
    ser.write((cmd + "\n").encode())
    # No prompt expected after jump — firmware takes over
    time.sleep(0.5)
    log_ok(f"Jump to 0x{addr:08x} issued.")


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def parse_args():
    parser = argparse.ArgumentParser(
        description="Load firmware binary into IRAM via shell commands."
    )
    parser.add_argument("binary", metavar="BINARY", help="Path to .bin file")
    parser.add_argument("--port",    default="/dev/ttyUSB0", help="Serial port (default: /dev/ttyUSB0)")
    parser.add_argument("--baud",    default=115200, type=int, help="Baud rate (default: 115200)")
    parser.add_argument("--addr",    default="0x00900000", help="Load/jump address (default: 0x00900000)")
    parser.add_argument("--no-reboot", action="store_true", help="Skip reboot, shell already running")
    parser.add_argument("--no-jump",   action="store_true", help="Load only, do not jump")
    parser.add_argument("--timeout",   default=10.0, type=float, help="Serial read timeout in seconds (default: 10)")
    return parser.parse_args()


def main():
    args = parse_args()
    addr = int(args.addr, 16)

    # Load binary
    try:
        with open(args.binary, "rb") as f:
            data = f.read()
    except OSError as e:
        die(f"Cannot open binary: {e}")

    log(f"Binary: {args.binary} ({len(data)} bytes)")
    log(f"Load address: 0x{addr:08x}")
    log(f"Port: {args.port} @ {args.baud} baud")
    print()

    # Open serial port
    try:
        ser = serial.Serial(args.port, args.baud, timeout=args.timeout)
    except serial.SerialException as e:
        die(f"Cannot open serial port: {e}")

    time.sleep(0.1)  # let port settle

    try:
        # Step 1 — reboot and wait for shell
        if not args.no_reboot:
            print("[ Step 1/3 ] Rebooting device...")
            step_reboot(ser, args.timeout)
        else:
            print("[ Step 1/3 ] Skipping reboot, waiting for prompt...")
            step_ensure_prompt(ser)
        print()

        # Step 2 — upload binary
        for attempt in range(1, 3):
            print(f"[ Step 2/3 ] Uploading {len(data)} bytes to 0x{addr:08x}...")
            fw_crc = step_load(ser, addr, data, args.timeout)
            if step_verify(data, fw_crc):
                print()
                break

            print()
            log_warn(f"Upload failed (attempt {attempt}/2), retrying...")
            print()
            ser.write(b"\x03")
            ser.reset_input_buffer()
            wait_for_prompt(ser, 2)
        else:
            die("Upload failed after 2 attempts.")

        # Step 3 — jump
        if not args.no_jump:
            print(f"[ Step 3/3 ] Jumping to 0x{addr:08x}...")
            step_jump(ser, addr, args.timeout)
            log_ok("Done.")
        else:
            log("--no-jump specified, skipping jump.")

    finally:
        ser.close()


if __name__ == "__main__":
    main()