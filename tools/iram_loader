#!/usr/bin/env python3
"""
iram_flash.py — load a firmware binary into IRAM via shell commands.

Usage:
    python3 iram_flash.py [--port PORT] [--baud BAUD] [--speed SPEED] [--addr ADDR] [--no-reboot] BINARY

Arguments:
    BINARY              Path to .bin file (e.g. build/freertos_shell--iram.bin)

Options:
    --port PORT         Serial port (default: /dev/ttyUSB0)
    --baud BAUD         Baud rate   (default: 115200)
    --speed SPEED       Switch to this baud rate before upload (e.g. 921600),
                        then switch back after. Device must support 'speed' command.
    --addr ADDR         Load address in hex (default: 0x00900000)
    --no-reboot         Skip reboot step, assume shell is already running
    --no-jump           Load binary but do not jump to entry point
    --timeout SECONDS   Serial read timeout in seconds (default: 10)
"""

import sys
import time
import argparse
import serial
import zlib


# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

def log(msg: str):
    print(f"  {msg}", flush=True)


def log_ok(msg: str):
    print(f"  \033[32m✓\033[0m {msg}", flush=True)


def log_debug(msg: str):
    print(f"  \033[34m#\033[0m {msg}", flush=True)


def log_warn(msg: str):
    print(f"  \033[33m!\033[0m {msg}", flush=True)


def log_err(msg: str):
    print(f"  \033[31m✗\033[0m {msg}", flush=True)


def die(msg: str):
    log_err(msg)
    sys.exit(1)


def elapsed(t: float) -> str:
    return f"{time.monotonic() - t:.1f}s"


# ---------------------------------------------------------------------------
# Serial helpers
# ---------------------------------------------------------------------------

def serial_write_slow(ser: serial.Serial, data: bytes, byte_delay: float = 0.005) -> None:
    """
    Write *data* to the serial port one byte at a time with a short pause
    between each byte.  Useful for commands where the receiver drops bytes
    when the host sends a burst too fast.

    byte_delay — seconds between bytes (default 5 ms).  Tune with
                 --byte-delay if the default is too slow or still lossy.
    """
    for b in data:
        ser.write(bytes([b]))
        ser.flush()
        time.sleep(byte_delay)


def readline(ser: serial.Serial, timeout: float = 2.0) -> tuple[str, bool]:
    ser.timeout = 0.1
    buf = b''
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        c = ser.read(1)
        if not c:
            continue
        if c in (b'\r', b'\n'):
            line = buf.decode(errors="ignore").strip()
            if line == '':
                continue
            return line, False
        buf += c
    return buf.decode(errors="ignore").strip(), True  # True = timeout


def wait_for_prompt(ser: serial.Serial, timeout: float = 2.0) -> bool:
    """
    Read lines until we see a bare '>' prompt (no spaces — shell convention).
    Returns True on success, False on timeout.
    """
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        line, is_timeout = readline(ser, 1)
        if line == ">":
            return True
        if is_timeout:
            ser.write(b"\x03")
    return False


# ---------------------------------------------------------------------------
# Steps
# ---------------------------------------------------------------------------

def step_reboot(ser: serial.Serial, timeout: float):
    log("Sending Ctrl+C to clear shell input...")
    ser.write(b"\x03\x03")
    time.sleep(0.2)
    ser.reset_input_buffer()

    log("Sending reboot command...")
    ser.write(b"reboot\n")

    log("Waiting for shell prompt after reboot...")
    if not wait_for_prompt(ser, timeout):
        die("Timed out waiting for shell prompt after reboot.")
    log_ok("Shell is ready.")


def step_ensure_prompt(ser: serial.Serial):
    """Used with --no-reboot: send Ctrl+C, expect prompt immediately."""
    ser.write(b"\x03")
    ser.reset_input_buffer()

    if not wait_for_prompt(ser, timeout=2.0):
        die("No shell prompt detected. Is the device running?")
    log_ok("Shell is ready.")
    time.sleep(0.2)
    ser.reset_input_buffer()


def step_switch_speed(ser: serial.Serial, new_baud: int, timeout: float) -> bool:
    """
    Send 'speed <baud>' to the device and switch the host port to match.

    The device responds with 'OK <baud>\\r\\n' at the OLD baud rate, then
    immediately switches.  We read the response, then change ser.baudrate
    on the host side.

    Returns True on success, False if the command was rejected or timed out.
    """
    cmd = f"speed {new_baud}"
    log(f"Switching baud rate: sending '{cmd}'")
    serial_write_slow(ser, (cmd + "\n").encode())

    # Echo
    echo, is_timeout = readline(ser, timeout)
    if echo != cmd:
        log_warn(f"Echo mismatch: {echo!r} (expected {cmd!r})")

    # Response: "OK <baud>"
    response, is_timeout = readline(ser, timeout)
    if is_timeout:
        log_err("Timed out waiting for speed response.")
        return False

    expected = f"OK {new_baud}"
    if response != expected:
        log_err(f"Unexpected speed response: {response!r} (expected {expected!r})")
        return False

    # Device has switched — now switch the host port
    ser.flush()
    time.sleep(0.1)  # brief pause to let the device UART flush its TX
    ser.baudrate = new_baud
    time.sleep(0.1)  # let the port settle

    log_ok(f"Baud rate switched to {new_baud}.")
    return True


def step_load(ser: serial.Serial, addr: int, data: bytes, timeout: float, max_cmd_retries: int = 3) -> int:
    """
    Send loadi command, stream binary, verify DONE + CRC.
    Returns CRC32 reported by firmware.

    The command line is sent byte-by-byte (byte_delay between each byte) to
    avoid dropped characters on slower targets.  If the device replies with
    "Invalid checksum" instead of "READY" the command is retried up to
    max_cmd_retries times before giving up.
    """
    size = len(data)
    cmd = f"loadi 0x{addr:08x} {size} 0x{addr + size:08x}"

    for cmd_attempt in range(1, max_cmd_retries + 1):
        if cmd_attempt > 1:
            log_warn(f"Retrying loadi command (attempt {cmd_attempt}/{max_cmd_retries})...")

        ser.write(b"\x03")
        time.sleep(0.1)
        ser.reset_input_buffer()

        log(f"Sending (slow): {cmd}")
        serial_write_slow(ser, (cmd + "\n").encode())

        # Read echo
        echo, is_timeout = readline(ser, timeout)
        if echo != cmd.strip():
            log_warn(f"echo mismatch: {echo!r}")

        # Wait for READY or error
        ready, is_timeout = readline(ser, timeout)
        if ready == "READY":
            log_ok("Device is ready to receive data.")
            break
        elif "Invalid checksum" in ready:
            log_warn(f"Device reported: {ready!r}")
            if cmd_attempt < max_cmd_retries:
                continue
            die(f"loadi rejected with '{ready}' after {max_cmd_retries} attempts.")
        else:
            die(f"Expected READY, got: {ready!r}")

    # Stream binary in chunks for progress reporting
    chunk_size = 512
    sent = 0
    t_start = time.monotonic()
    while sent < size:
        chunk = data[sent:sent + chunk_size]
        ser.write(chunk)
        sent += len(chunk)
        pct = sent * 100 // size
        elapsed = time.monotonic() - t_start
        speed = sent / elapsed / 1024 if elapsed > 0 else 0
        print(f"\r  Uploading... {sent}/{size} bytes ({pct}%) {speed:.1f} KB/s", end="", flush=True)

    print()  # newline after progress

    # Wait for DONE <crc32>
    done_line, is_timeout = readline(ser, timeout)
    if not done_line.startswith("DONE"):
        die(f"Expected DONE <crc32>, got: {done_line!r}")

    parts = done_line.split()
    if len(parts) != 2:
        die(f"Malformed DONE line: {done_line!r}")

    fw_crc = int(parts[1], 16)
    return fw_crc


def step_verify(data: bytes, fw_crc: int) -> bool:
    local_crc = zlib.crc32(data)
    if local_crc != fw_crc:
        log_warn(f"CRC mismatch! local=0x{local_crc:08x} firmware=0x{fw_crc:08x}")
        return False
    log_ok(f"CRC32 OK: 0x{local_crc:08x}")
    return True


def step_jump(ser: serial.Serial, addr: int, timeout: float):
    cmd = f"go 0x{addr:08x}"
    log(f"Sending (slow): {cmd}")
    serial_write_slow(ser, (cmd + "\n").encode())
    # No prompt expected after jump — firmware takes over
    time.sleep(0.5)
    log_ok(f"Jump to 0x{addr:08x} issued.")


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def parse_args():
    parser = argparse.ArgumentParser(
        description="Load firmware binary into IRAM via shell commands."
    )
    parser.add_argument("binary", metavar="BINARY", help="Path to .bin file")
    parser.add_argument("--port", default="/dev/ttyUSB0", help="Serial port (default: /dev/ttyUSB0)")
    parser.add_argument("--baud", default=115200, type=int, help="Baud rate (default: 115200)")
    parser.add_argument("--speed", default=None, type=int,
                        help="Switch to this baud rate before upload (e.g. 921600). "
                             "Device must support the 'speed' shell command. "
                             "The port is restored to --baud after the session.")
    parser.add_argument("--addr", default="0x00900000", help="Load/jump address (default: 0x00900000)")
    parser.add_argument("--no-reboot", action="store_true", help="Skip reboot, shell already running")
    parser.add_argument("--no-jump", action="store_true", help="Load only, do not jump")
    parser.add_argument("--timeout", default=10.0, type=float, help="Serial read timeout in seconds (default: 10)")
    return parser.parse_args()


def main():
    args = parse_args()
    addr = int(args.addr, 16)

    # Load binary
    try:
        with open(args.binary, "rb") as f:
            data = f.read()
    except OSError as e:
        die(f"Cannot open binary: {e}")

    log(f"Binary: {args.binary} ({len(data)} bytes)")
    log(f"Load address: 0x{addr:08x}")
    log(f"Port: {args.port} @ {args.baud} baud")
    if args.speed:
        log(f"Upload speed: {args.speed} baud")
    print()

    # Open serial port at the initial baud rate (always 115200 after reset)
    try:
        ser = serial.Serial(args.port, args.baud, timeout=args.timeout)
    except serial.SerialException as e:
        die(f"Cannot open serial port: {e}")

    time.sleep(0.1)  # let port settle

    try:
        t_total = time.monotonic()

        # Step 1 — reboot and wait for shell
        if not args.no_reboot:
            print("[ Step 1/4 ] Rebooting device...")
            step_reboot(ser, args.timeout)
        else:
            print("[ Step 1/4 ] Skipping reboot, waiting for prompt...")
            step_ensure_prompt(ser)
        print()

        # Step 2 — optionally switch to faster baud rate
        if args.speed and args.speed != args.baud:
            print(f"[ Step 2/4 ] Switching to {args.speed} baud...")
            if not step_switch_speed(ser, args.speed, args.timeout):
                die("Failed to switch baud rate.")
        else:
            print("[ Step 2/4 ] No baud rate switch requested, skipping.")
        print()

        # Step 3 — upload binary
        for attempt in range(1, 3):
            print(f"[ Step 3/4 ] Uploading {len(data)} bytes to 0x{addr:08x}...")
            fw_crc = step_load(ser, addr, data, args.timeout)
            if step_verify(data, fw_crc):
                print()
                break

            print()
            log_warn(f"Upload failed (attempt {attempt}/2), retrying...")
            print()
            ser.write(b"\x03")
            ser.reset_input_buffer()
            wait_for_prompt(ser, 0.5)
        else:
            die("Upload failed after 2 attempts.")

        # Step 4 — jump
        if not args.no_jump:
            print(f"[ Step 4/4 ] Jumping to 0x{addr:08x}...")
            step_jump(ser, addr, args.timeout)
            log_ok(f"Done in {elapsed(t_total)}.")
            print()
        else:
            log("--no-jump specified, skipping jump.")

    finally:
        ser.close()


if __name__ == "__main__":
    main()